</script> <script>// in case if Google Search Ads are used,
// it violates ScreenshotOne's Affiliate Program Terms of Service (https://screenshotone.com/affiliate-program/)
const googleAdsLocalStorageKey = "screenshotone_google_ads_visit";

function shouldRemoveReferralCookies() {
    const currentUrl = new URL(window?.location?.href);
    const referrer = document.referrer ? new URL(document.referrer) : null;
    const adParams = [
        // Google Ads
        "gclid",
        "gad_source",
        "gad_campaignid",
        "gbraid",
        "wbraid"
    ];
    const isGoogleAdsVisit = adParams.some(param => currentUrl?.searchParams?.has(param));
    const isGoogleReferrer = /(^|\.)google\./.test(referrer?.hostname || "");

    if (isGoogleAdsVisit || isGoogleReferrer) {
        try {
            window.localStorage.setItem(googleAdsLocalStorageKey, "true");
        } catch (e) {}
    }

    try {
        return (
            isGoogleAdsVisit ||
            isGoogleReferrer ||
            window.localStorage.getItem(googleAdsLocalStorageKey) === "true"
        );
    } catch (e) {
        return isGoogleAdsVisit || isGoogleReferrer;
    }
}

function removeReferralCookies() {
    const referralCookieNames = ["tolt_referral", "tolt_data"];
    if (shouldRemoveReferralCookies()) {
        const domains = [
            window.location.hostname,
            "." + window.location.hostname.split(".").slice(-2).join("."),
            window.location.hostname.split(".").slice(-2).join("."),
        ];
        for (const cookieName of referralCookieNames) {
            for (const domain of domains) {
                document.cookie = `${cookieName}=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/; domain=${domain}`;
            }
            document.cookie = `${cookieName}=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/`;
        }
    }
}

// call it at least once
removeReferralCookies();

// periodically check for referral cookies in case of
// race conditions with the referral program script
const interval = setInterval(removeReferralCookies, 100);
setTimeout(() => clearInterval(interval), 10000);
</script> <script async src="https://cdn.tolt.io/tolt.js" data-tolt="fd8471b4-5248-4d88-b73a-34e0921ee5bf"></script><link rel="stylesheet" href="/_astro/index.CnHfZnG0.css">
